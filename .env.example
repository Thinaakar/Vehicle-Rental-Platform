
# Local development — copy to .env.local
FIREBASE_CREDENTIALS=src/config/ServiceAccountKey.json
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
SESSION_SECRET=change-me-in-production-use-long-random-string
PASSWORD_SALT=drivexpro-rental

# Production deploy (Vercel/Railway/etc.) — do NOT use file paths; use inline JSON:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}
# FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
# SESSION_SECRET=long-random-production-secret
# PASSWORD_SALT=your-production-salt
